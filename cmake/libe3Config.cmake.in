@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Threads REQUIRED)

if(@LIBE3_ENABLE_ZMQ@)
    find_dependency(PkgConfig)
    if(PkgConfig_FOUND)
        pkg_check_modules(ZMQ IMPORTED_TARGET libzmq)
    endif()
endif()

# If libe3 was built with JSON support, make downstream consumers find nlohmann/json
if(@LIBE3_ENABLE_JSON@)
    find_dependency(nlohmann_json 3.11 REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/libe3Targets.cmake")

check_required_components(libe3)
