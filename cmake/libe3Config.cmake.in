@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Threads REQUIRED)

if(@LIBE3_ENABLE_ZMQ@)
    find_dependency(PkgConfig)
    if(PkgConfig_FOUND)
        pkg_check_modules(ZMQ IMPORTED_TARGET libzmq)
    endif()
endif()

# nlohmann/json is intentionally NOT a find_dependency: it is header-only and
# used only inside libe3's implementation (compiled into the library, scoped to
# the BUILD interface in libe3Targets.cmake), so consumers of the installed
# library never need it. Requiring it here would make find_package(libe3) fail
# on machines without a system-wide nlohmann_json for no reason.

# If libe3 was built with Protobuf support, make downstream consumers find Protobuf
if(@LIBE3_ENABLE_PROTOBUF@)
    find_dependency(Protobuf REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/libe3Targets.cmake")

check_required_components(libe3)
